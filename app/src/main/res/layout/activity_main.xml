<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtAppName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="DermaSkin"
            android:textAlignment="center"
            android:textColor="@color/brown_dark"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAppSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Triagem inteligente de manchas na pele"
            android:textAlignment="center"
            android:textColor="@color/text_dark"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_circle"
            android:padding="26dp"
            android:src="@drawable/ic_skin_placeholder" />

        <LinearLayout
            android:id="@+id/cardAuth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/txtMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Criar conta"
                android:textColor="@color/brown_dark"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtModeDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Cadastre-se para acessar a análise inteligente da sua pele."
                android:textColor="@color/text_dark"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_input"
                android:hint="Nome completo"
                android:inputType="textPersonName"
                android:padding="16dp"
                android:textColor="@color/text_dark"
                android:textColorHint="#8A6B5A"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="E-mail"
                android:inputType="textEmailAddress"
                android:padding="16dp"
                android:textColor="@color/text_dark"
                android:textColorHint="#8A6B5A"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:hint="Senha"
                android:inputType="textPassword"
                android:padding="16dp"
                android:textColor="@color/text_dark"
                android:textColorHint="#8A6B5A"
                android:textSize="15sp" />

            <CheckBox
                android:id="@+id/checkTerms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Entendo que o DermaSkin realiza apenas uma triagem por IA e não substitui consulta médica."
                android:textColor="@color/text_dark"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="18dp"
                android:backgroundTint="@color/brown"
                android:text="Criar conta"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="17sp" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/soft_brown"
                android:text="Já tenho conta"
                android:textAllCaps="false"
                android:textColor="@color/brown_dark"
                android:textSize="16sp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="18dp"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Ao notar crescimento, sangramento, coceira, mudança de cor ou formato, procure um dermatologista."
            android:textAlignment="center"
            android:textColor="@color/text_dark"
            android:textSize="13sp" />

    </LinearLayout>

</ScrollView>