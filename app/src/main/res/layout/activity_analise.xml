<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp"
        tools:ignore="WebViewLayout">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DermaSkin"
            android:textAlignment="center"
            android:textColor="@color/brown_dark"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Análise inteligente de manchas na pele"
            android:textAlignment="center"
            android:textColor="@color/text_dark"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/imgPreview"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_circle"
            android:padding="8dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_skin_placeholder" />

        <EditText
            android:id="@+id/edtDiameter"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card"
            android:hint="Diâmetro aproximado em mm. Ex: 7"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:textColor="@color/text_dark"
            android:textColorHint="#8A6B5A"
            android:textSize="15sp" />

        <CheckBox
            android:id="@+id/checkEvolution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="A mancha mudou de tamanho, cor, formato ou começou a coçar/sangrar?"
            android:textColor="@color/text_dark"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnCamera"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/brown"
            android:text="Tirar foto da mancha"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

        <Button
            android:id="@+id/btnAnalyze"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/brown_dark"
            android:enabled="false"
            android:text="Analisar com IA"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

        <Button
            android:id="@+id/btnExportPdf"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/soft_brown"
            android:enabled="false"
            android:text="Exportar relatório em PDF"
            android:textAllCaps="false"
            android:textColor="@color/brown_dark"
            android:textSize="16sp" />

        <ProgressBar
            android:id="@+id/progress"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtRiskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resultado"
                android:textAlignment="center"
                android:textColor="@color/brown_dark"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPercentage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="0%"
                android:textAlignment="center"
                android:textColor="@color/danger"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Descrição do resultado"
                android:textAlignment="center"
                android:textColor="@color/text_dark"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtAbcdeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Análise ABCDE"
                android:textColor="@color/brown_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtABCDE"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/text_dark"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtClasses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:textColor="@color/text_dark"
                android:textSize="14sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Atenção: este aplicativo não substitui consulta médica. A análise é apenas uma triagem por inteligência artificial."
            android:textAlignment="center"
            android:textColor="@color/text_dark"
            android:textSize="13sp" />

        <WebView
            android:id="@+id/webViewIA"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="invisible" />

    </LinearLayout>

</ScrollView>